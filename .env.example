# ============================================
# YanAI Docker Compose 环境变量配置示例
# 复制为 .env 后再按自己的服务器修改
# ============================================

# 你的镜像地址。正式服务器不需要 clone 代码，只拉取这个镜像。
# GitHub Container Registry 示例：ghcr.io/your-github-user/yanai:latest
YANAI_IMAGE=ghcr.io/your-github-user/yanai:latest

# 宿主机访问端口
YANAI_PORT=3000

# 容器时区
TZ=Asia/Shanghai

# 认证密钥（必填）
CHATGPT2API_AUTH_KEY=your_secret_key_here

# 基础 URL（可选，用于生成图片 URL）
# CHATGPT2API_BASE_URL=https://your-domain.com

# ============================================
# 存储后端配置
# ============================================

# 存储后端类型（可选值: json, sqlite, postgres, git）
# 默认建议使用 sqlite；多人稳定并发生产环境建议改为 postgres。
STORAGE_BACKEND=sqlite

# ============================================
# 数据库配置（当 STORAGE_BACKEND=sqlite/postgres 时使用）
# ============================================

# SQLite 示例：留空时程序会自动使用 /app/data/accounts.db
# 如需显式指定，容器内绝对路径需要 4 个斜杠：
# DATABASE_URL=sqlite:////app/data/accounts.db
DATABASE_URL=

# 外部 PostgreSQL 示例
# DATABASE_URL=postgresql://user:password@host:5432/yanai

# Supabase 示例
# DATABASE_URL=postgresql://postgres.xxx:password@aws-1-us-west-1.pooler.supabase.com:5432/postgres

# docker-compose.postgres.yml 内置 PostgreSQL 示例
# POSTGRES_DB=yanai
# POSTGRES_USER=yanai
# POSTGRES_PASSWORD=change_me_to_a_long_random_password

# ============================================
# Git 仓库配置（当 STORAGE_BACKEND=git 时使用）
# ============================================

# Git 仓库地址（必填）
# GIT_REPO_URL=https://github.com/your-username/your-private-repo.git

# Git 访问令牌（必填）
# GitHub: your_github_token_here
# GitLab: your_gitlab_token_here
# GIT_TOKEN=your_git_token_here

# Git 分支（可选，默认: main）
# GIT_BRANCH=main

# Git 仓库中的文件路径（可选，默认位于仓库根目录）
# GIT_FILE_PATH=accounts.json
# GIT_AUTH_KEYS_FILE_PATH=auth_keys.json
# GIT_USERS_FILE_PATH=users.json
# GIT_SESSIONS_FILE_PATH=sessions.json
# GIT_REDEEM_CODES_FILE_PATH=redeem_codes.json
# GIT_CHANNELS_FILE_PATH=channels.json
# GIT_PROMPT_LIBRARY_FILE_PATH=prompt_library.json
# GIT_IMAGE_RECORDS_FILE_PATH=image_records.json

# 如果远程仓库把运行时数据放在 data/ 目录，可以改成：
# GIT_FILE_PATH=data/accounts.json
# GIT_AUTH_KEYS_FILE_PATH=data/auth_keys.json
# GIT_USERS_FILE_PATH=data/users.json
# GIT_SESSIONS_FILE_PATH=data/sessions.json
# GIT_REDEEM_CODES_FILE_PATH=data/redeem_codes.json
# GIT_CHANNELS_FILE_PATH=data/channels.json
# GIT_PROMPT_LIBRARY_FILE_PATH=data/prompt_library.json
# GIT_IMAGE_RECORDS_FILE_PATH=data/image_records.json

# ============================================
# 注册邮箱验证 / Linux DO OAuth（可选）
# ============================================

# SMTP 也可以在 config.json 的设置页中配置
# CHATGPT2API_SMTP_HOST=smtp.example.com
# CHATGPT2API_SMTP_PORT=587
# CHATGPT2API_SMTP_USERNAME=notice@example.com
# CHATGPT2API_SMTP_PASSWORD=your_smtp_password
# CHATGPT2API_SMTP_FROM=notice@example.com

# Linux DO Connect OAuth App
# LINUX_DO_CLIENT_ID=your_linuxdo_client_id
# LINUX_DO_CLIENT_SECRET=your_linuxdo_client_secret

# ============================================
# WARP / FlareSolverr（可选）
# ============================================

# docker-compose.warp.yml 默认暴露：
# - privoxy: http://127.0.0.1:8118
# - flaresolverr: http://127.0.0.1:8191
# 在系统设置页启用“WARP / FlareSolverr 代理运行时”后，可填写：
# proxy_url=http://privoxy:8118
# flaresolverr_url=http://flaresolverr:8191
